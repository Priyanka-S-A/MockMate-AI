# Server Port
PORT=5000

# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai_interview_practice?retryWrites=true&w=majority

# JWT Token Configuration
JWT_SECRET=super_secret_jwt_passphrase_change_this_in_production
JWT_EXPIRES_IN=7d

# Gemini API Key — get yours FREE from https://aistudio.google.com/apikey
# Key must start with "AIza..." (e.g. AIzaSy...)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
